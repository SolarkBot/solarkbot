# ====== App ======
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-random-secret-here
APP_DOMAIN=localhost:3000

# ====== AI Provider ======
AI_PROVIDER=anthropic
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
AI_MODEL=claude-sonnet-4-20250514

# ====== Solana ======
SOLANA_NETWORK=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# ====== x402 Payments ======
MERCHANT_WALLET_ADDRESS=your-solana-wallet-address
CHAT_PRICE_USDC=0.001
AGENT_TASK_PRICE_USDC=0.01
FREE_MESSAGES_PER_DAY=10

# ====== Database ======
DATABASE_URL=postgresql://solarkbot:password@localhost:5432/solarkbot
POSTGRES_PASSWORD=your-db-password

# ====== Redis ======
REDIS_URL=redis://localhost:6379

# ====== Agent ======
AGENT_MAX_SPEND_USDC=100
