# Local development defaults.
# If you browse the app on http://127.0.0.1:3000 instead of localhost,
# update these URLs to match that host for the cleanest cookie/link behavior.

# ====== App ======
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
BETTER_AUTH_SECRET=generate-a-random-32-byte-secret-here
NEXT_PUBLIC_ENABLE_LUCID_AGENTS=false
NEXT_PUBLIC_BETTER_AUTH_INFRA_ENABLED=false
BETTER_AUTH_API_KEY=
BETTER_AUTH_API_URL=
BETTER_AUTH_KV_URL=

# Legacy fallback envs (optional)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-random-32-byte-secret-here
APP_DOMAIN=localhost:3000

# ====== AI Provider ======
AI_PROVIDER=groq
GROQ_API_KEY=gsk_your_groq_api_key
GROQ_BASE_URL=https://api.groq.com/openai/v1
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_MODEL=llama-3.1-8b-instant

# ====== Solana ======
SOLANA_NETWORK=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_NETWORK=devnet
SOLSCAN_API_KEY=
SOLSCAN_API_BASE_URL=https://pro-api.solscan.io/v2.0

# ====== x402 Payments ======
MERCHANT_WALLET_ADDRESS=your-solana-wallet-address
CHAT_PRICE_USDC=0.001
AGENT_TASK_PRICE_USDC=0.01
FREE_MESSAGES_PER_DAY=10

# ====== Database ======
DATABASE_URL=postgresql://solarkbot:password@localhost:5432/solarkbot
PRISMA_DB_PUSH_ON_BUILD=false
POSTGRES_PASSWORD=your-db-password

# ====== Redis ======
REDIS_URL=redis://localhost:6379

# ====== Agent ======
AGENT_MAX_SPEND_USDC=100

# Production notes:
# - Set BETTER_AUTH_URL, NEXT_PUBLIC_APP_URL, and NEXTAUTH_URL to https://solarkbot.xyz
# - Use hosted DATABASE_URL and REDIS_URL values; do not use localhost on Vercel
# - Set MERCHANT_WALLET_ADDRESS in production so payment-gated flows work correctly
